generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int                  @id @default(autoincrement())
  email              String?              @unique
  phone              String?              @unique
  passwordHash       String?              @map("password_hash")
  firstName          String?              @map("first_name")
  lastName           String?              @map("last_name")
  role               UserRole
  isActive           Boolean              @default(true) @map("is_active")
  isBlocked          Boolean              @default(false) @map("is_blocked")
  blockedAt          DateTime?            @map("blocked_at")
  blockedReason      String?              @map("blocked_reason")
  isVerified         Boolean              @default(false) @map("is_verified")
  lastLoginAt        DateTime?            @map("last_login_at")
  createdAt          DateTime             @default(now()) @map("created_at")
  updatedAt          DateTime             @updatedAt @map("updated_at")
  administrator      Administrator?
  auditLogs          AuditLog[]
  securityLogs       SecurityLog[]
  blockActions       BlockHistory[]       @relation("blockPerformer")
  bookingSessions    BookingSession[]     @relation("bookingUser")
  breathingSessions  BreathingSession[]
  chatParticipants   ChatParticipant[]
  comments           Comment[]
  communityPosts     CommunityPost[]
  communityPostLikes CommunityPostLike[]
  assignedComplaints Complaint[]          @relation("assignedTo")
  complaints         Complaint[]          @relation("reporter")
  resolvedComplaints Complaint[]          @relation("resolver")
  contentModerations ContentModeration[]  @relation("contentModerator")
  diaryEntries       DiaryEntry[]
  habitLogs          HabitLog[]
  habits             Habit[]
  meetingParticipant MeetingParticipant[]
  meetingHost        Meeting[]            @relation("host")
  sentMessages       Message[]
  mobileUser         MobileUser?
  moderationActions  ModerationAction[]
  assignedReports    ModerationReport[]   @relation("reportAssignee")
  createdReports     ModerationReport[]   @relation("reportCreator")
  resolvedReports    ModerationReport[]   @relation("reportResolver")
  moodEntries        MoodEntry[]
  notifications      Notification[]
  otpVerifications   OtpVerification[]
  payments           Payment[]
  psychologist       Psychologist?
  savedItems         SavedItem[]
  sessions           Session[]
  sleepRecords       SleepRecord[]
  superadmin         Superadmin?
  testResults        TestResult[]
  transactions       Transaction[]
  reviews            Review[]
  consumerSubscriptions ConsumerSubscription[]
  sosAlerts                   SosAlert[]
  aiPsychologistConversations AiPsychologistConversation[]
  mobilePushDevices           MobilePushDevice[]

  @@map("users")
}

model Role {
  id          Int              @id @default(autoincrement())
  name        String
  description String?
  isSystem    Boolean          @default(false) @map("is_system")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  centerId    Int?             @map("center_id")
  permissions Permission[]
  center      EducationCenter? @relation(fields: [centerId], references: [id], onDelete: Cascade)

  @@unique([name, centerId])
  @@map("roles")
}

model Permission {
  id        Int      @id @default(autoincrement())
  roleId    Int      @map("role_id")
  resource  String
  action    String
  createdAt DateTime @default(now()) @map("created_at")
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, resource, action])
  @@map("permissions")
}

model Session {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  refreshToken String   @map("refresh_token")
  deviceInfo   String?  @map("device_info")
  ipAddress    String?  @map("ip_address")
  isRevoked    Boolean  @default(false) @map("is_revoked")
  expiresAt    DateTime @map("expires_at")
  createdAt    DateTime @default(now()) @map("created_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model OtpVerification {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  phone     String?
  email     String?
  code      String
  purpose   String
  isUsed    Boolean  @default(false) @map("is_used")
  attempts  Int      @default(0)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("otp_verifications")
}

model Superadmin {
  id               Int      @id @default(autoincrement())
  userId           Int      @unique @map("user_id")
  firstName        String   @map("first_name")
  lastName         String   @map("last_name")
  twoFactorEnabled Boolean  @default(false) @map("two_factor_enabled")
  twoFactorSecret  String?  @map("two_factor_secret")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("superadmins")
}

model EducationCenter {
  id                Int                @id @default(autoincrement())
  name              String
  address           String?
  phone             String?
  email             String?
  description       String?
  logoUrl           String?            @map("logo_url")
  subscriptionPlan  SubscriptionPlan   @default(BASIC) @map("subscription_plan")
  centerTariffPlanId Int?              @map("center_tariff_plan_id")
  isActive          Boolean            @default(true) @map("is_active")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  centerTariffPlan  CenterTariffPlan?  @relation(fields: [centerTariffPlanId], references: [id])
  administrators    Administrator[]
  auditLogs         AuditLog[]
  centerPayments    CenterPayment[]
  complaints        Complaint[]
  courses           Course[]
  groups            Group[]
  moderationReports ModerationReport[]
  payments          Payment[]
  psychologists     Psychologist[]
  roles             Role[]
  staff             Staff[]
  students          Student[]
  teachers          Teacher[]
  transactions      Transaction[]

  @@map("education_centers")
}

model Administrator {
  id        Int             @id @default(autoincrement())
  userId    Int             @unique @map("user_id")
  centerId  Int             @map("center_id")
  firstName String          @map("first_name")
  lastName  String          @map("last_name")
  position  String?
  invitedBy Int?            @map("invited_by")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")
  center    EducationCenter @relation(fields: [centerId], references: [id], onDelete: Cascade)
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("administrators")
}

model MobileUser {
  id               Int       @id @default(autoincrement())
  userId           Int       @unique @map("user_id")
  firstName        String?   @map("first_name")
  lastName         String?   @map("last_name")
  avatarUrl        String?   @map("avatar_url")
  dateOfBirth      DateTime? @map("date_of_birth") @db.Date
  gender           String?
  bio              String?
  pinHash          String?   @map("pin_hash")
  biometricEnabled Boolean   @default(false) @map("biometric_enabled")
  isPremium        Boolean   @default(false) @map("is_premium")
  premiumUntil     DateTime? @map("premium_until")
  consumerPlanId   Int?      @map("consumer_plan_id")
  onboardingCompletedAt DateTime? @map("onboarding_completed_at")
  /** JSON: { pushEnabled, emailEnabled, remindersEnabled, marketingEnabled, moodReminder, sessionReminder } */
  notificationPrefs Json?    @map("notification_prefs")
  analyticsOptIn    Boolean   @default(false) @map("analytics_opt_in")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  consumerPlan     ConsumerPlan? @relation(fields: [consumerPlanId], references: [id])

  @@map("mobile_users")
}

model Psychologist {
  id                 Int                @id @default(autoincrement())
  userId             Int                @unique @map("user_id")
  centerId           Int?               @map("center_id")
  firstName          String             @map("first_name")
  lastName           String             @map("last_name")
  patronymic         String?
  gender             String?
  dateOfBirth        DateTime?          @map("date_of_birth") @db.Date
  specialization     String?
  bio                String?
  avatarUrl          String?            @map("avatar_url")
  licenseNumber      String?            @map("license_number")
  education          String?
  certifications     String[]           @default([])
  experienceYears    Int?               @map("experience_years")
  verificationStatus VerificationStatus @default(PENDING) @map("verification_status")
  isVerified         Boolean            @default(false) @map("is_verified")
  isAvailable        Boolean            @default(true) @map("is_available")
  rejectionReason    String?            @map("rejection_reason")
  hourlyRate         Int?               @map("hourly_rate")
  rating             Float?
  totalSessions      Int                @default(0) @map("total_sessions")
  createdAt          DateTime           @default(now()) @map("created_at")
  updatedAt          DateTime           @updatedAt @map("updated_at")
  bookingSessions    BookingSession[]
  center             EducationCenter?   @relation(fields: [centerId], references: [id])
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("psychologists")
}

model Teacher {
  id        Int             @id @default(autoincrement())
  centerId  Int             @map("center_id")
  firstName String          @map("first_name")
  lastName  String          @map("last_name")
  subject   String?
  phone     String?
  email     String?
  isActive  Boolean         @default(true) @map("is_active")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")
  center    EducationCenter @relation(fields: [centerId], references: [id], onDelete: Cascade)

  @@map("teachers")
}

model Staff {
  id        Int             @id @default(autoincrement())
  centerId  Int             @map("center_id")
  firstName String          @map("first_name")
  lastName  String          @map("last_name")
  position  String?
  phone     String?
  email     String?
  roleId    Int?            @map("role_id")
  isActive  Boolean         @default(true) @map("is_active")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")
  center    EducationCenter @relation(fields: [centerId], references: [id], onDelete: Cascade)

  @@map("staff")
}

model Student {
  id          Int             @id @default(autoincrement())
  centerId    Int             @map("center_id")
  firstName   String          @map("first_name")
  lastName    String          @map("last_name")
  phone       String?
  email       String?
  dateOfBirth DateTime?       @map("date_of_birth") @db.Date
  isActive    Boolean         @default(true) @map("is_active")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  payments    CenterPayment[]
  enrollments Enrollment[]
  center      EducationCenter @relation(fields: [centerId], references: [id], onDelete: Cascade)

  @@map("students")
}

model Course {
  id            Int             @id @default(autoincrement())
  centerId      Int             @map("center_id")
  description   String?
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  code          String?
  durationWeeks Int?            @map("duration_weeks")
  name          String
  status        CourseStatus    @default(DRAFT)
  center        EducationCenter @relation(fields: [centerId], references: [id], onDelete: Cascade)
  enrollments   Enrollment[]
  groups        Group[]

  @@unique([centerId, code])
  @@map("courses")
}

model Group {
  id          Int             @id @default(autoincrement())
  centerId    Int             @map("center_id")
  courseId    Int?            @map("course_id")
  name        String
  description String?
  maxStudents Int?            @map("max_students")
  isActive    Boolean         @default(true) @map("is_active")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  enrollments Enrollment[]
  center      EducationCenter @relation(fields: [centerId], references: [id], onDelete: Cascade)
  course      Course?         @relation(fields: [courseId], references: [id])

  @@map("groups")
}

model Enrollment {
  id          Int             @id @default(autoincrement())
  studentId   Int             @map("student_id")
  courseId    Int?            @map("course_id")
  groupId     Int?            @map("group_id")
  status      String          @default("active")
  enrolledAt  DateTime        @default(now()) @map("enrolled_at")
  completedAt DateTime?       @map("completed_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  payments    CenterPayment[]
  course      Course?         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  group       Group?          @relation(fields: [groupId], references: [id])
  student     Student         @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("enrollments")
}

model Test {
  id          Int          @id @default(autoincrement())
  title       String
  description String?
  category    String?
  type        String       @default("psychological")
  duration    Int?
  imageUrl    String?      @map("image_url")
  isPublished Boolean      @default(false) @map("is_published")
  createdBy   Int?         @map("created_by")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  questions   Question[]
  testResults TestResult[]

  @@map("tests")
}

model Question {
  id         Int      @id @default(autoincrement())
  testId     Int      @map("test_id")
  text       String
  type       String   @default("single_choice")
  orderIndex Int      @default(0) @map("order_index")
  imageUrl   String?  @map("image_url")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")
  answers    Answer[]
  test       Test     @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@map("questions")
}

model Answer {
  id         Int      @id @default(autoincrement())
  questionId Int      @map("question_id")
  text       String
  isCorrect  Boolean  @default(false) @map("is_correct")
  score      Int      @default(0)
  orderIndex Int      @default(0) @map("order_index")
  createdAt  DateTime @default(now()) @map("created_at")
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@map("answers")
}

model TestResult {
  id             Int       @id @default(autoincrement())
  testId         Int       @map("test_id")
  userId         Int       @map("user_id")
  score          Int?
  maxScore       Int?      @map("max_score")
  responses      Json?
  interpretation String?
  completedAt    DateTime? @map("completed_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  test           Test      @relation(fields: [testId], references: [id], onDelete: Cascade)
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("test_results")
}

model Chat {
  id              Int               @id @default(autoincrement())
  type            ChatType          @default(DIRECT)
  title           String?
  imageUrl        String?           @map("image_url")
  createdBy       Int?              @map("created_by")
  isActive        Boolean           @default(true) @map("is_active")
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  bookingSessions BookingSession[]
  participants    ChatParticipant[]
  messages        Message[]

  @@map("chats")
}

model ChatParticipant {
  id         Int       @id @default(autoincrement())
  chatId     Int       @map("chat_id")
  userId     Int       @map("user_id")
  joinedAt   DateTime  @default(now()) @map("joined_at")
  leftAt     DateTime? @map("left_at")
  lastReadAt DateTime? @map("last_read_at")
  chat       Chat      @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@map("chat_participants")
}

model Message {
  id            Int      @id @default(autoincrement())
  chatId        Int      @map("chat_id")
  senderId      Int      @map("sender_id")
  content       String?
  type          String   @default("text")
  attachmentUrl String?  @map("attachment_url")
  isRead        Boolean  @default(false) @map("is_read")
  isDeleted     Boolean  @default(false) @map("is_deleted")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  chat          Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender        User     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  title     String
  body      String?
  type      String   @default("general")
  isRead    Boolean  @default(false) @map("is_read")
  metadata  String?
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Announcement {
  id             Int       @id @default(autoincrement())
  title          String
  content        String
  type           String    @default("general")
  targetAudience String    @default("all") @map("target_audience")
  centerId       Int?      @map("center_id")
  isPublished    Boolean   @default(false) @map("is_published")
  publishedAt    DateTime? @map("published_at")
  expiresAt      DateTime? @map("expires_at")
  createdBy      Int?      @map("created_by")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@map("announcements")
}

model CommunityPost {
  id            Int       @id @default(autoincrement())
  authorId      Int       @map("author_id")
  title         String?
  content       String
  imageUrl      String?   @map("image_url")
  likesCount    Int       @default(0) @map("likes_count")
  commentsCount Int       @default(0) @map("comments_count")
  isPublished   Boolean   @default(true) @map("is_published")
  isFlagged     Boolean   @default(false) @map("is_flagged")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  comments      Comment[]
  likes         CommunityPostLike[]
  author        User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("community_posts")
}

model CommunityPostLike {
  id        Int           @id @default(autoincrement())
  postId    Int           @map("post_id")
  userId    Int           @map("user_id")
  createdAt DateTime      @default(now()) @map("created_at")
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId, createdAt])
  @@map("community_post_likes")
}

model Comment {
  id         Int           @id @default(autoincrement())
  postId     Int           @map("post_id")
  authorId   Int           @map("author_id")
  content    String
  parentId   Int?          @map("parent_id")
  likesCount Int           @default(0) @map("likes_count")
  isFlagged  Boolean       @default(false) @map("is_flagged")
  createdAt  DateTime      @default(now()) @map("created_at")
  updatedAt  DateTime      @updatedAt @map("updated_at")
  author     User          @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent     Comment?      @relation("CommentThread", fields: [parentId], references: [id])
  children   Comment[]     @relation("CommentThread")
  post       CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@map("comments")
}

model Complaint {
  id                Int                @id @default(autoincrement())
  reporterId        Int                @map("reporter_id")
  targetType        String             @map("target_type")
  targetId          Int                @map("target_id")
  subject           String
  description       String?
  status            ComplaintStatus    @default(NEW)
  priority          ComplaintPriority  @default(MEDIUM)
  assignedToUserId  Int?               @map("assigned_to_user_id")
  resolutionNote    String?            @map("resolution_note")
  resolvedBy        Int?               @map("resolved_by")
  resolvedAt        DateTime?          @map("resolved_at")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  centerId          Int?               @map("center_id")
  assignedTo        User?              @relation("assignedTo", fields: [assignedToUserId], references: [id])
  center            EducationCenter?   @relation(fields: [centerId], references: [id])
  reporter          User               @relation("reporter", fields: [reporterId], references: [id], onDelete: Cascade)
  resolver          User?              @relation("resolver", fields: [resolvedBy], references: [id])
  moderationActions ModerationAction[]

  @@map("complaints")
}

model ModerationReport {
  id               Int              @id @default(autoincrement())
  type             String
  targetType       String           @map("target_type")
  targetId         Int              @map("target_id")
  summary          String
  details          String?
  severity         ReportSeverity   @default(MEDIUM)
  status           ReportStatus     @default(NEW)
  createdByUserId  Int              @map("created_by_user_id")
  assignedToUserId Int?             @map("assigned_to_user_id")
  resolutionNote   String?          @map("resolution_note")
  resolvedBy       Int?             @map("resolved_by")
  resolvedAt       DateTime?        @map("resolved_at")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  centerId         Int?             @map("center_id")
  assignedTo       User?            @relation("reportAssignee", fields: [assignedToUserId], references: [id])
  center           EducationCenter? @relation(fields: [centerId], references: [id])
  createdBy        User             @relation("reportCreator", fields: [createdByUserId], references: [id])
  resolver         User?            @relation("reportResolver", fields: [resolvedBy], references: [id])

  @@map("moderation_reports")
}

model BlockHistory {
  id          Int      @id @default(autoincrement())
  targetType  String   @map("target_type")
  targetId    Int      @map("target_id")
  action      String
  reason      String?
  performedBy Int      @map("performed_by")
  createdAt   DateTime @default(now()) @map("created_at")
  performer   User     @relation("blockPerformer", fields: [performedBy], references: [id])

  @@map("block_history")
}

model ContentModeration {
  id            Int                     @id @default(autoincrement())
  contentType   String                  @map("content_type")
  contentId     Int                     @map("content_id")
  contentTitle  String?                 @map("content_title")
  status        ContentModerationStatus @default(PENDING)
  moderatorId   Int?                    @map("moderator_id")
  moderatorNote String?                 @map("moderator_note")
  reviewedAt    DateTime?               @map("reviewed_at")
  createdAt     DateTime                @default(now()) @map("created_at")
  updatedAt     DateTime                @updatedAt @map("updated_at")
  moderator     User?                   @relation("contentModerator", fields: [moderatorId], references: [id])

  @@map("content_moderation")
}

model ModerationAction {
  id          Int        @id @default(autoincrement())
  moderatorId Int        @map("moderator_id")
  targetType  String     @map("target_type")
  targetId    Int        @map("target_id")
  action      String
  reason      String?
  complaintId Int?       @map("complaint_id")
  createdAt   DateTime   @default(now()) @map("created_at")
  complaint   Complaint? @relation(fields: [complaintId], references: [id])
  moderator   User       @relation(fields: [moderatorId], references: [id])

  @@map("moderation_actions")
}

model Article {
  id            Int       @id @default(autoincrement())
  title         String
  slug          String    @unique
  content       String
  excerpt       String?
  coverImageUrl String?   @map("cover_image_url")
  category      String?
  tags          String[]
  authorId      Int?      @map("author_id")
  isPublished   Boolean   @default(false) @map("is_published")
  publishedAt   DateTime? @map("published_at")
  viewCount     Int       @default(0) @map("view_count")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  @@map("articles")
}

model Banner {
  id         Int       @id @default(autoincrement())
  title      String
  imageUrl   String    @map("image_url")
  linkUrl    String?   @map("link_url")
  position   String    @default("home")
  orderIndex Int       @default(0) @map("order_index")
  isActive   Boolean   @default(true) @map("is_active")
  startsAt   DateTime? @map("starts_at")
