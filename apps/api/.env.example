# --- Core ---
NODE_ENV=development
PORT=3001
DATABASE_URL=postgresql://user:pass@localhost:5432/ruhiyat
JWT_SECRET=change-me-min-32-chars-production
JWT_REFRESH_SECRET=change-me-min-32-chars-refresh-different-from-jwt
JWT_PASSWORD_RESET_SECRET=optional-separate-secret-for-reset-jwt
# Access JWT (default 15m). SUPERADMIN may use shorter value via JWT_ACCESS_EXPIRES_IN_SUPERADMIN.
JWT_ACCESS_EXPIRES_IN=15m
JWT_ACCESS_EXPIRES_IN_SUPERADMIN=15m
# Refresh JWT + DB session row TTL (rotation). SUPERADMIN defaults shorter (e.g. 1d) if unset.
JWT_REFRESH_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN_SUPERADMIN=1d
# Session binding on refresh: UA on by default; IP optional (mobile / CGNAT).
AUTH_SESSION_BIND_UA=true
AUTH_SESSION_BIND_IP=false
# Optional: cookie Domain for refresh (multi-subdomain). Leave unset for host-only.
# REFRESH_COOKIE_DOMAIN=.example.com

# Step-up JWT (after POST /auth/verify-password) — short window for sensitive mutations.
JWT_STEP_UP_EXPIRES_IN=5m
# Optional separate secret; defaults to JWT_SECRET + ".step-up.v1"
# JWT_STEP_UP_SECRET=

# --- Trust / HTTPS (production, reverse proxy orqali) ---
TRUST_PROXY=1
ENFORCE_HTTPS=false
CORS_ORIGINS=https://app.example.com,https://admin.example.com

# --- SMS (productionda telefon OTP uchun majburiy) ---
# Haqiqiy SMS uchun provayder hisobidan foydalanasiz (masalan Eskiz.uz) — xabar uchun balans/tarif bo‘yicha to‘lov.
# Dev: SMS_PROVIDER=none — SMS yuborilmaydi (OTP konsolga AUTH_DEV_LOG_OTP bilan).
# Production telefon ro‘yxatdan o‘tish: SMS_PROVIDER=eskiz + ESKIZ_EMAIL + ESKIZ_PASSWORD majburiy.
SMS_PROVIDER=eskiz
ESKIZ_EMAIL=
ESKIZ_PASSWORD=
# Eskiz panelda tasdiqlangan yuboruvchi raqam / nomi
ESKIZ_SMS_FROM=4546
# SMS_PROVIDER=twilio
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# --- Email (email orqali ro‘yxatdan o‘tish / parol tiklash uchun majburiy) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# From manzil (ko‘pincha SMTP_USER bilan bir xil yoki verified domain)
SMTP_FROM=noreply@example.com

# Dev: OTP konsolga / javobda qaytarish (faqat non-production)
# AUTH_DEV_LOG_OTP=true
# AUTH_DEV_RETURN_OTP=true

# Ro‘yxatdan o‘tish OTP ni butunlay o‘tkazib yuborish (faqat dev)
# AUTH_SKIP_REGISTER_OTP=false

# --- OpenAI (test natijasi AI, kayfiyat xulosasi, AI psixolog) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- CLICK (premium) ---
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_SECRET_KEY=
CLICK_RETURN_URL=ruhiyat://payment-return

# Qo‘lda premium tasdiqlash (faqat staging/test)
PAYMENT_ALLOW_MANUAL_CONFIRM=false
