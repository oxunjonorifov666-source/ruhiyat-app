{
  "name": "@ruhiyat/api",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "build:prod": "nest build && prisma db push && node dist/seed.js",
    "seed": "ts-node --compiler-options '{\"module\":\"commonjs\"}' src/seed.ts",
    "start": "node dist/main",
    "start:prod": "node dist/main",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:push-force": "prisma db push --accept-data-loss",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.3",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "^11.1.3",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.3",
    "@nestjs/platform-socket.io": "^11.1.18",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/websockets": "^11.1.18",
    "@prisma/client": "^6.10.1",
    "@ruhiyat/types": "workspace:*",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "helmet": "^8.1.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@nestjs/schematics": "^11.0.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "catalog:",
    "@types/passport-jwt": "^4.0.1",
    "prisma": "^6.10.1",
    "typescript": "^5.8.3"
  }
}
