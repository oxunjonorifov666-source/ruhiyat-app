{
  "expo": {
    "name": "Ruhiyat",
    "slug": "ruhiyat",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "experiments": {
      "autolinkingModuleResolution": true
    },
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#6366f1"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsLocalNetworking": true,
          "NSExceptionDomains": {
            "localhost": {
              "NSExceptionAllowsInsecureHTTPLoads": true,
              "NSIncludesSubdomains": true
            },
            "127.0.0.1": {
              "NSExceptionAllowsInsecureHTTPLoads": true
            }
          }
        }
      }
    },
    "android": {
      "package": "com.ruhiyat.app",
      "usesCleartextTraffic": false,
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#6366f1"
      },
      "versionCode": 2,
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "scheme": "ruhiyat",
    "extra": {
      "apiUrl": "https://ruhiyat-app.onrender.com/api",
      "startupEnableNotifications": true,
      "startupEnableQueryPersist": false,
      "eas": {
        "projectId": "4c32c656-e2a2-47b4-8854-a2e9888036a7"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Profil rasmi uchun galereyaga ruxsat.",
          "cameraPermission": "Profil surati uchun kameraga ruxsat."
        }
      ],
      [
        "expo-calendar",
        {
          "calendarPermission": "Seans eslatmalari uchun kalendar."
        }
      ]
    ]
  }
}
